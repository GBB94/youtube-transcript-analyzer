# Phase 1 needs none of these (offline, uploaded_file only).
# Later phases:
# YOUTUBE_API_KEY=            # Phase 6 discovery (dual-bucket quota; see DESIGN.md §8)
# MANAGED_API_KEY=            # Phase 5 managed provider (native captions / ASR)
# WHISPER_MODEL=small         # Phase 4 (pin a revision in code)
# WHISPER_COMPUTE_TYPE=int8
# TRANSCRIPT_CACHE_DIR=~/.cache/transcript-tool
# Cookies are opt-in only and never auto-read; pass an explicit, dedicated file.
